  "query": "\n        SELECT\n            offer_id,\n            txid,\n            vout,\n            utxo_type AS \"utxo_type: UtxoType\",\n            created_at_height,\n            spent_txid,\n            spent_at_height\n        FROM offer_utxos\n        WHERE offer_id = $1\n          AND spent_txid IS NULL\n        ORDER BY created_at_height ASC\n        ",
